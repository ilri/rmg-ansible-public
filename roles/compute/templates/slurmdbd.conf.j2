#
# Example slurmdbd.conf file.
#
# See the slurmdbd.conf man page for more information.
#
# Archive info
#ArchiveJobs=yes
#ArchiveDir="/tmp"
#ArchiveSteps=yes
#ArchiveScript=
#JobPurge=12
#StepPurge=1
#
# Authentication info
AuthType=auth/munge
#AuthInfo=/var/run/munge/munge.socket.2
#
# slurmDBD info
DbdAddr={{ hostvars[slurm_head_node].ansible_ssh_host | default("192.168.1.2") }}
DbdHost={{ slurm_head_node | default("hpc01") }}
#DbdPort=7031
SlurmUser=slurm
#MessageTimeout=300
DebugLevel=4
#DefaultQOS=normal,standby
LogFile=/var/log/slurm/slurmdbd.log
PidFile=/var/run/slurmdbd.pid
#PluginDir=/usr/lib/slurm
#PrivateData=accounts,users,usage,jobs
#TrackWCKey=yes
#
# Database info
StorageType=accounting_storage/mysql
StorageHost={{ slurmdb_info.db_hostname | default("db.example.co.ke") }}
#StoragePort=1234
StoragePass={{ slurmdb_info.db_password | default("example-complex-passs")}}
StorageUser={{ slurmdb_info.db_user | default("slurm") }}
StorageLoc={{ slurmdb_info.db_name | default("slurm_db") }}
